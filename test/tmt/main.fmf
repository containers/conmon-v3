/validate:
    summary: Validate test (lint and format check)
    test: |
        make -C ../.. .install.fmt
        export PATH="$HOME/.cargo/bin:$PATH"
        make -C ../.. lint
    require:
        - cargo
        - clippy
        - git-core
        - make
        - rustfmt
        - systemd-devel
    duration: 5m
    adjust:
        enabled: false
        when: initiator is not defined or initiator != packit
    environment:
        RUST_BACKTRACE: 1

/unit:
    summary: Unit tests
    test: make -C ../.. unit
    require:
        - cargo
        - make
        - systemd-devel
    duration: 10m
    adjust:
        enabled: false
        when: initiator is not defined or initiator != packit
    environment:
        RUST_BACKTRACE: 1

/e2e:
    summary: End-to-end tests
    test: bash e2e.sh
    require:
        - bats
        - binutils
        - conmon-v3
        - git-core
        - jq
        - runc
        - socat
    duration: 15m
    environment:
        RUST_BACKTRACE: 1

/podman:
    summary: Podman system tests with conmon-v3
    test: bash podman.sh
    require:
        - conmon-v3
        - runc
        - crun
    duration: 60m
    environment:
        PODMAN_TESTING: /usr/bin/podman-testing
        RUST_BACKTRACE: 1
